    <entry xml:lang="en">
        <title>Grow smarter with embedded Rust</title>
        <published>2025-06-04T00:00:00+00:00</published>
        <updated>2025-06-04T00:00:00+00:00</updated>
        
        <author>
          <name>
            
              Willem Vanhulle
            
          </name>
        </author>
        
        <link rel="alternate" type="text/html" href="https://sysghent.be/events/plant-pot/"/>
        <id>https://sysghent.be/events/plant-pot/</id>
        
        <content type="html" xml:base="https://sysghent.be/events/plant-pot/">&lt;p&gt;Tasks for participants of the workshop are available at &lt;a href=&quot;https:&#x2F;&#x2F;github.com&#x2F;sysghent&#x2F;plant-pot&quot;&gt;github&lt;&#x2F;a&gt;.&lt;&#x2F;p&gt;
&lt;pre data-lang=&quot;rust&quot; style=&quot;background-color:#f9f9f9;color:#111111;&quot; class=&quot;language-rust &quot;&gt;&lt;code class=&quot;language-rust&quot; data-lang=&quot;rust&quot;&gt;&lt;span style=&quot;color:#8959a8;&quot;&gt;fn &lt;&#x2F;span&gt;&lt;span style=&quot;color:#4271ae;&quot;&gt;main&lt;&#x2F;span&gt;&lt;span&gt;() {
&lt;&#x2F;span&gt;&lt;span&gt;    &lt;&#x2F;span&gt;&lt;span style=&quot;color:#8959a8;&quot;&gt;let mut&lt;&#x2F;span&gt;&lt;span&gt; pot &lt;&#x2F;span&gt;&lt;span style=&quot;color:#3e999f;&quot;&gt;= &lt;&#x2F;span&gt;&lt;span&gt;PlantPot::new();
&lt;&#x2F;span&gt;&lt;span&gt;    pot.&lt;&#x2F;span&gt;&lt;span style=&quot;color:#4271ae;&quot;&gt;water&lt;&#x2F;span&gt;&lt;span&gt;();
&lt;&#x2F;span&gt;&lt;span&gt;    pot.&lt;&#x2F;span&gt;&lt;span style=&quot;color:#4271ae;&quot;&gt;fertilize&lt;&#x2F;span&gt;&lt;span&gt;();
&lt;&#x2F;span&gt;&lt;span&gt;    pot.&lt;&#x2F;span&gt;&lt;span style=&quot;color:#4271ae;&quot;&gt;check_health&lt;&#x2F;span&gt;&lt;span&gt;();
&lt;&#x2F;span&gt;&lt;span&gt;}
&lt;&#x2F;span&gt;&lt;&#x2F;code&gt;&lt;&#x2F;pre&gt;
&lt;p&gt;&lt;img src=&quot;&#x2F;events&#x2F;grow_smarter.jpg&quot; alt=&quot;Plant Pot&quot; &#x2F;&gt;&lt;&#x2F;p&gt;
</content>
        
